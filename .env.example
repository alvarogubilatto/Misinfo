# =============================================================================
# MisInfo — Variables de entorno
# Copiá este archivo como .env y completá los valores reales.
# NUNCA commitees .env al repositorio.
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE — Frontend (Vite expone solo las variables VITE_*)
# Encontrás estos valores en: Supabase Dashboard > Settings > API
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# -----------------------------------------------------------------------------
# SUPABASE — Backend / Server-side (Node.js + Express, F1 Abr 2026)
# La service role key bypasea RLS. NUNCA exponerla al cliente.
# Encontrás este valor en: Supabase Dashboard > Settings > API > service_role
# -----------------------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# -----------------------------------------------------------------------------
# CIFRADO — Vault de credenciales (AES-256)
# Generá una clave segura con: openssl rand -base64 32
# Esta clave cifra/descifra las credenciales del vault en el cliente.
# Si la perdés, los datos cifrados son irrecuperables.
# -----------------------------------------------------------------------------
VITE_ENCRYPTION_KEY=reemplazar-con-32-bytes-en-base64

# -----------------------------------------------------------------------------
# GMAIL API — Detección automática de cobros (F3 - Jul 2026)
# Configurar en: Google Cloud Console > APIs > Gmail API > Credenciales OAuth 2.0
# Scope requerido: https://www.googleapis.com/auth/gmail.readonly
# -----------------------------------------------------------------------------
VITE_GMAIL_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...
GMAIL_REDIRECT_URI=http://localhost:5173/auth/gmail/callback

# -----------------------------------------------------------------------------
# GEMINI FLASH — NLP para parsing de emails (F3 - Jul 2026)
# Obtené la key en: Google AI Studio > Get API key
# Free tier: 15 RPM, suficiente para MVP
# -----------------------------------------------------------------------------
GEMINI_API_KEY=AIza...

# -----------------------------------------------------------------------------
# SENDGRID — Notificaciones por email (F2 - May 2026)
# Crear cuenta en sendgrid.com > Settings > API Keys
# Free tier: 100 emails/día, suficiente para MVP
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=noreply@misinfo.ar

# -----------------------------------------------------------------------------
# APP — Configuración general
# -----------------------------------------------------------------------------
VITE_APP_NAME=MisInfo
VITE_APP_ENV=development
